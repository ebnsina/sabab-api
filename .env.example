# Copy to .env and adjust. This one file is read by BOTH docker compose and the
# Go services, so a port lives in exactly one place.
#
# If you already run Postgres, Redis or ClickHouse natively, the container's
# published port will collide with it — and a native server on 127.0.0.1:5432
# quietly wins over Docker's mapping, so the app connects to the wrong database
# and reports a confusing "role does not exist". Move the published port here
# (e.g. POSTGRES_PORT=5433) and update the matching DSN below.

SABAB_ENV=development
SABAB_LOG_LEVEL=info

# --- Control plane (Postgres) ---------------------------------------------
POSTGRES_PORT=5432
SABAB_POSTGRES_DSN=postgres://sabab:sabab@localhost:5432/sabab?sslmode=disable

# --- Event plane (ClickHouse, native protocol) -----------------------------
SABAB_CLICKHOUSE_ADDR=localhost:9000
SABAB_CLICKHOUSE_DATABASE=sabab
SABAB_CLICKHOUSE_USERNAME=sabab
SABAB_CLICKHOUSE_PASSWORD=sabab

# --- Queue (Redis Streams) -------------------------------------------------
SABAB_REDIS_ADDR=localhost:6379
SABAB_REDIS_PASSWORD=
SABAB_REDIS_DB=0

# --- Object store (MinIO): release artifacts, source maps ------------------
# Port 9002, not 9000: ClickHouse's native protocol owns 9000.
SABAB_S3_ENDPOINT=localhost:9002
SABAB_S3_REGION=us-east-1
SABAB_S3_BUCKET=sabab-artifacts
SABAB_S3_ACCESS_KEY=sabab
SABAB_S3_SECRET_KEY=sabab-secret
SABAB_S3_USE_SSL=false

# --- Services --------------------------------------------------------------
SABAB_GATEWAY_ADDR=:8080  # move if 8080 is taken locally
SABAB_API_ADDR=:8081

# --- Processor -------------------------------------------------------------
SABAB_PROCESSOR_BATCH_SIZE=128
SABAB_PROCESSOR_CONCURRENCY=8

# --- Alerter ---------------------------------------------------------------
# How often frequency-threshold rules are evaluated. New-issue and regression
# alerts are event-driven and do not wait for this.
SABAB_ALERTER_FREQUENCY_INTERVAL=1m
# The public dashboard URL, used to build "view issue" links in alerts.
SABAB_DASHBOARD_URL=http://localhost:5173

# --- SMTP (optional) — leave HOST empty to log alerts instead of emailing ---
SABAB_SMTP_HOST=
SABAB_SMTP_PORT=587
SABAB_SMTP_USERNAME=
SABAB_SMTP_PASSWORD=
SABAB_SMTP_FROM=alerts@sabab.local

# --- docker-compose credentials (must agree with the SABAB_* values above) --
POSTGRES_USER=sabab
POSTGRES_PASSWORD=sabab
POSTGRES_DB=sabab
CLICKHOUSE_USER=sabab
CLICKHOUSE_PASSWORD=sabab
CLICKHOUSE_DB=sabab
S3_ACCESS_KEY=sabab
S3_SECRET_KEY=sabab-secret
S3_BUCKET=sabab-artifacts
